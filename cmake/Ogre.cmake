include(FetchContent)

FetchContent_Declare(
	ogre
	URL https://github.com/OGRECave/ogre/archive/refs/tags/v1.11.6.tar.gz
)

set(OGRE_BUILD_SAMPLES OFF CACHE BOOL "" FORCE)
set(OGRE_BUILD_TOOLS OFF CACHE BOOL "" FORCE)
set(OGRE_STATIC ON CACHE BOOL "" FORCE)
set(OGRE_BUILD_DEPENDENCIES OFF CACHE BOOL "" FORCE)
set(OGRE_BUILD_COMPONENT_VOLUME OFF CACHE BOOL "" FORCE)
set(OGRE_BUILD_COMPONENT_PAGING OFF CACHE BOOL "" FORCE)
set(OGRE_BUILD_COMPONENT_PROPERTY OFF CACHE BOOL "" FORCE)
set(OGRE_BUILD_COMPONENT_MESHLODGENERATOR OFF CACHE BOOL "" FORCE)
set(OGRE_BUILD_COMPONENT_HLMS OFF CACHE BOOL "" FORCE)
set(OGRE_BUILD_PLUGIN_BSP OFF CACHE BOOL "" FORCE)
set(OGRE_BUILD_PLUGIN_PCZ OFF CACHE BOOL "" FORCE)
set(OGRE_BUILD_PLUGIN_PFX OFF CACHE BOOL "" FORCE)
set(OGRE_BUILD_RENDERSYSTEM_D3D9 OFF CACHE BOOL "" FORCE)
set(OGRE_BUILD_RENDERSYSTEM_D3D11 OFF CACHE BOOL "" FORCE)
set(OGRE_BUILD_RENDERSYSTEM_GLES2 OFF CACHE BOOL "" FORCE)
set(OGRE_CONFIG_ENABLE_ZIP OFF CACHE BOOL "" FORCE)
set(OGRE_ENABLE_PRECOMPILED_HEADERS OFF CACHE BOOL "" FORCE)
set(OGRE_BUILD_COMPONENT_JAVA OFF CACHE BOOL "" FORCE)
set(OGRE_BUILD_COMPONENT_CSHARP OFF CACHE BOOL "" FORCE)
set(OGRE_BUILD_COMPONENT_PYTHON OFF CACHE BOOL "" FORCE)

set(CMAKE_POLICY_VERSION_MINIMUM 3.5)

FetchContent_MakeAvailable(ogre)

if (TARGET OgreMain)
	target_include_directories(OgreMain PRIVATE $<BUILD_INTERFACE:${CMAKE_BINARY_DIR}/include>)
	add_library(Ogre::OgreMain ALIAS OgreMain)
endif ()
if (TARGET OgreBites)
	target_include_directories(OgreBites PRIVATE $<BUILD_INTERFACE:${CMAKE_BINARY_DIR}/include>)
	add_library(Ogre::OgreBites ALIAS OgreBites)
endif ()
if (TARGET OgreOverlay)
	target_include_directories(OgreOverlay PRIVATE $<BUILD_INTERFACE:${CMAKE_BINARY_DIR}/include>)
	add_library(Ogre::OgreOverlay ALIAS OgreOverlay)
endif ()
if (TARGET OgreTerrain)
	target_include_directories(OgreTerrain PRIVATE $<BUILD_INTERFACE:${CMAKE_BINARY_DIR}/include>)
	add_library(Ogre::OgreTerrain ALIAS OgreTerrain)
endif ()